# Copy this file to .env and fill in your values.
# The worker reads these at startup.

# ── Redis ──────────────────────────────────────────────────────────────────────
# URL of the Redis instance publishing the sec:filings:8k queue.
# When running alongside admin_backend's compose stack, use:
#   REDIS_URL=redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0
REDIS_QUEUE_NAME=sec:filings:8k
REDIS_DEAD_LETTER_QUEUE=sec:filings:dlq:8k
REDIS_MAX_ATTEMPTS=3
REDIS_RETRY_DELAY_SECONDS=5

# ── MongoDB ────────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/
DATABASE_NAME=normalize_data

# ── LLM provider ──────────────────────────────────────────────────────────────
# "deepseek" | "groq" | "gemini" | "ollama"
LLM_PROVIDER=deepseek

# DeepSeek (recommended for production)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_REQUEST_TIMEOUT=120

# Groq (fast, free tier available)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Ollama (local — set OLLAMA_BASE_URL to reach it from inside Docker)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_NUM_CTX=32768

# ── Extraction tuning ──────────────────────────────────────────────────────────
# Ask the LLM to echo a verbatim source snippet per metric (__sources__) so the
# source-grounding checker can catch hallucinated values. Roughly doubles LLM
# output size / generation time, so OFF by default. Set to 1 for accuracy-
# critical runs.
SOURCE_GROUNDING=0

# Prune the extraction prompt to concepts the company reported in its last N
# stored periods. Drops dimensional [Member] segments and retired line items
# that bloat the prompt and are almost never in the current filing. Set to 0
# to disable pruning (send the full concept list).
PROMPT_HISTORY_PERIODS=3
