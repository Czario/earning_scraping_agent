# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=earnings_db
MONGODB_COLLECTION=earnings

# LLM provider selector: ollama | openai | groq
LLM_PROVIDER=ollama

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# OpenAI (used only when LLM_PROVIDER=openai)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_REQUEST_TIMEOUT=60

# Groq (used only when LLM_PROVIDER=groq)
# GROQ_API_KEY=
# GROQ_MODEL=openai/gpt-oss-120b
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# GROQ_REQUEST_TIMEOUT=60

# Concurrency tuning
# OLLAMA_CONCURRENCY = max simultaneous LLM calls across ALL company threads.
# Default 1 (safe for a single-threaded local Ollama). Raise to 2-4 if you
# ALSO start the Ollama server with OLLAMA_NUM_PARALLEL set to the same value:
#   OLLAMA_NUM_PARALLEL=4 ollama serve
# Without OLLAMA_NUM_PARALLEL on the server side, raising this here will cause
# request timeouts.
OLLAMA_CONCURRENCY=1

# OLLAMA_NUM_PARALLEL = number of chunks of ONE company that the extract node
# fires in parallel. Same caveat: only raise if the Ollama server supports it.
OLLAMA_NUM_PARALLEL=1
